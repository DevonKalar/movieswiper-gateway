# Required
JWT_SECRET=change-me

# Optional — defaults shown
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=

CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

RATE_LIMIT_DEFAULT=100/minute

DOWNSTREAM_TIMEOUT_SECONDS=10.0
DOWNSTREAM_MAX_RETRIES=3
DOWNSTREAM_RETRY_BACKOFF=0.5

# Service routing: SERVICES__{name}=http://host:port
# Longest-prefix match is used when multiple prefixes overlap.
# Proxy strips {name} from the path and forwards the rest to the upstream service.
SERVICES__movies=http://movies-service:8000
SERVICES__users=http://users-service:8001
